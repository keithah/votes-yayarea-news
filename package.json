{
  "name": "votes-yayarea-news",
  "version": "0.1.0",
  "private": true,
  "description": "Static Next.js site for votes.yayarea.news.",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "validate-data": "tsx scripts/validate-data.ts",
    "validate-ingestion": "tsx scripts/validate-ingestion.ts",
    "report:source-coverage": "tsx scripts/report-source-coverage.ts",
    "report:source-race-coverage": "tsx scripts/report-source-race-coverage.ts",
    "ingest:sources": "tsx scripts/ingest-sources.ts",
    "extract:positions": "tsx scripts/extract-positions.ts",
    "validate-extraction": "tsx scripts/validate-extraction.ts",
    "review:positions": "tsx scripts/review-positions.ts",
    "review:coverage": "tsx scripts/report-reviewed-position-coverage.ts",
    "verify:s01": "bash scripts/verify-s01.sh",
    "test:data": "node --import tsx --test tests/data/*.test.ts",
    "test:ingestion": "node --import tsx --test tests/ingestion/*.test.ts",
    "test:extraction": "node --import tsx --test tests/extraction/*.test.ts",
    "verify:s02": "bash scripts/verify-s02.sh",
    "verify:s03": "bash scripts/verify-s03.sh",
    "verify:s04": "bash scripts/verify-s04.sh",
    "verify:s05": "bash scripts/verify-s05.sh",
    "verify:s06": "bash scripts/verify-s06.sh",
    "verify:s07": "bash scripts/verify-s07.sh",
    "verify:s08": "bash scripts/verify-s08.sh",
    "verify:s09": "bash scripts/verify-s09.sh"
  },
  "dependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
